Package: golden
Type: Package
Title: Framework for Patient-Level Microsimulation of Risk Factor Trajectories & Hazard-Based Events
Version: 0.0.1
Date: 2026-03-04
Authors@R: c(
    person("Pete", "Dodd",
        role = c("aut", "cre"),
